    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/subset-font": "^2.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-grab": "^0.1.29",
    "subset-font": "^2.4.0",
